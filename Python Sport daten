import statsmodels.api as sm
import numpy as np
import plotly.express as px

# Utiliser le DataFrame fourni
df = final_data

# Filtrer les années pour n'inclure que celles à partir de 1948
df = df[df['Year'] >= 1948]

# Ajouter les abréviations pour les équipes
abbreviations = {
    'United States': 'USA',
    'Soviet Union': 'SU',
    'China': 'CHN',
    'Egypt': 'EGY',
    'Italy': 'ITA',
    'Lithuania': 'LTU',
    'Germany': 'GER',
    'Brazil': 'BRA',
    'Argentina': 'ARG',
    'Spain': 'ESP'
}
df['Team_Abbr'] = df['Team'].map(abbreviations).fillna(df['Team'])

# Calculer le nombre total de joueurs NBA pour chaque équipe chaque année
nba_players_per_team_year = df.groupby(['Year', 'Team_Abbr']).agg(Total_NBA_Players=('NBA', 'sum')).reset_index()

# Associer chaque équipe avec le type de médaille gagnée ou aucune médaille
medals_per_team_year = df.dropna(subset=['Medal']).groupby(['Year', 'Team_Abbr']).agg(Medal=('Medal', 'first')).reset_index()
no_medals_per_team_year = df[df['Medal'].isna()].groupby(['Year', 'Team_Abbr']).agg(Medal=('Medal', lambda x: 'None')).reset_index()

# Combiner les données des médailles
combined_data = pd.concat([medals_per_team_year, no_medals_per_team_year])

# Combiner les données du nombre de joueurs NBA avec les types de médailles
final_data1 = pd.merge(nba_players_per_team_year, combined_data, on=['Year', 'Team_Abbr'])

# Filtrer pour n'inclure que les années spécifiques des Jeux Olympiques
years = list(range(1948, 2025, 4))
final_data1 = final_data1[final_data1['Year'].isin(years)]

# Ajouter une constante pour l'interception du modèle
final_data1['const'] = 1

# Fonction pour ajuster un modèle de régression de Poisson
def poisson_regression(data, medal_type):
    df_medal = data[data['Medal'] == medal_type]
    model = sm.GLM(df_medal['Total_NBA_Players'], df_medal[['const', 'Year']], family=sm.families.Poisson())
    result = model.fit()
    return result

# Ajuster les modèles pour chaque type de médaille
results_gold = poisson_regression(final_data1, 'Gold')
results_silver = poisson_regression(final_data1, 'Silver')
results_bronze = poisson_regression(final_data1, 'Bronze')
results_none = poisson_regression(final_data1, 'None')

# Afficher les résumés des modèles
print("Gold Medal Model:\n", results_gold.summary())
print("\nSilver Medal Model:\n", results_silver.summary())
print("\nBronze Medal Model:\n", results_bronze.summary())
print("\nNo Medal Model:\n", results_none.summary())

# Visualiser les prédictions
final_data1['Predicted_Gold'] = results_gold.predict(final_data1[['const', 'Year']])
final_data1['Predicted_Silver'] = results_silver.predict(final_data1[['const', 'Year']])
final_data1['Predicted_Bronze'] = results_bronze.predict(final_data1[['const', 'Year']])
final_data1['Predicted_None'] = results_none.predict(final_data1[['const', 'Year']])

# Calculer la différence entre les deux extrémités pour chaque type de médaille
gold_diff = final_data1[final_data1['Medal'] == 'Gold'].iloc[-1]['Predicted_Gold'] - final_data1[final_data1['Medal'] == 'Gold'].iloc[0]['Predicted_Gold']
silver_diff = final_data1[final_data1['Medal'] == 'Silver'].iloc[-1]['Predicted_Silver'] - final_data1[final_data1['Medal'] == 'Silver'].iloc[0]['Predicted_Silver']
bronze_diff = final_data1[final_data1['Medal'] == 'Bronze'].iloc[-1]['Predicted_Bronze'] - final_data1[final_data1['Medal'] == 'Bronze'].iloc[0]['Predicted_Bronze']
none_diff = final_data1[final_data1['Medal'] == 'None'].iloc[-1]['Predicted_None'] - final_data1[final_data1['Medal'] == 'None'].iloc[0]['Predicted_None']

# Créer le graphique des prédictions
fig = px.scatter(final_data1, x='Year', y='Total_NBA_Players', color='Medal',
                 color_discrete_map={'Gold': '#FFD700', 'Silver': '#C0C0C0', 'Bronze': '#CD7F32', 'None': '#808080'},
                 title='Number of NBA Players on Teams by Medal Type Over the Years')

# Ajouter les lignes de régression
fig.add_traces(px.line(final_data1, x='Year', y='Predicted_Gold').update_traces(line=dict(color='#FFD700')).data)
fig.add_traces(px.line(final_data1, x='Year', y='Predicted_Silver').update_traces(line=dict(color='#C0C0C0')).data)
fig.add_traces(px.line(final_data1, x='Year', y='Predicted_Bronze').update_traces(line=dict(color='#CD7F32')).data)
fig.add_traces(px.line(final_data1, x='Year', y='Predicted_None').update_traces(line=dict(color='gray')).data)

# Ajouter les segments de ligne pour visualiser les différences
fig.add_shape(type='line', x0=final_data1[final_data1['Medal'] == 'Gold'].iloc[0]['Year'],
              y0=final_data1[final_data1['Medal'] == 'Gold'].iloc[0]['Predicted_Gold'],
              x1=final_data1[final_data1['Medal'] == 'Gold'].iloc[-1]['Year'],
              y1=final_data1[final_data1['Medal'] == 'Gold'].iloc[-1]['Predicted_Gold'],
              line=dict(color='#FFD700', width=2, dash='dash'))


# Mettre à jour la mise en page pour une meilleure lisibilité
fig.update_layout(
    xaxis_title='Year',
    yaxis_title='Number of NBA Players',
    legend_title='Medal',
    plot_bgcolor='rgba(0,0,0,0)',
    paper_bgcolor='rgba(0,0,0,0)',
    font=dict(
        family="Arial",
        size=12,
        color="Black"
    ),
    xaxis=dict(
        showgrid=True,
        gridcolor='lightgray'
    ),
    yaxis=dict(
        showgrid=True,
        gridcolor='lightgray'
    )
)

# Ajouter des annotations pour les différences
fig.add_annotation(
    x=final_data1[final_data1['Medal'] == 'Gold'].iloc[-1]['Year'],
    y=final_data1[final_data1['Medal'] == 'Gold'].iloc[-1]['Predicted_Gold'],
    text=f'Gold Diff: {gold_diff:.2f}',
    showarrow=True,
    arrowhead=1,
    ax=0,
    ay=-40,
    bgcolor="rgba(255, 255, 255, 0.8)",
    bordercolor="black"
)

fig.add_annotation(
    x=final_data1[final_data1['Medal'] == 'Silver'].iloc[-1]['Year'],
    y=final_data1[final_data1['Medal'] == 'Silver'].iloc[-1]['Predicted_Silver'],
    text=f'Silver Diff: {silver_diff:.2f}',
    showarrow=True,
    arrowhead=1,
    ax=0,
    ay=-40,
    bgcolor="rgba(255, 255, 255, 0.8)",
    bordercolor="black"
)

fig.add_annotation(
    x=final_data1[final_data1['Medal'] == 'Bronze'].iloc[-1]['Year'],
    y=final_data1[final_data1['Medal'] == 'Bronze'].iloc[-1]['Predicted_Bronze'],
    text=f'Bronze Diff: {bronze_diff:.2f}',
    showarrow=True,
    arrowhead=1,
    ax=0,
    ay=-40,
    bgcolor="rgba(255, 255, 255, 0.8)",
    bordercolor="black"
)

fig.add_annotation(
    x=final_data1[final_data1['Medal'] == 'None'].iloc[-1]['Year'],
    y=final_data1[final_data1['Medal'] == 'None'].iloc[-1]['Predicted_None'],
    text=f'None Diff: {none_diff:.2f}',
    showarrow=True,
    arrowhead=1,
    ax=0,
    ay=-40,
    bgcolor="rgba(255, 255, 255, 0.8)",
    bordercolor="black"
)

fig.show()

