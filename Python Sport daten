import pandas as pd
import plotly.express as px

# Utiliser le DataFrame fourni
df = final_data

# Ajouter les abréviations pour les équipes
abbreviations = {
    'United States': 'USA',
    'Soviet Union': 'SU',
    'China': 'CHN',
    'Egypt': 'EGY',
    'Italy': 'ITA',
    'Lithuania': 'LTU',
    'Germany': 'GER',
    'Brazil': 'BRA',
    'Argentina': 'ARG',
    'Spain': 'ESP'
}
df['Team_Abbr'] = df['Team'].map(abbreviations).fillna(df['Team'])

# Filtrer le dataset pour les équipes ayant gagné des médailles
medal_winners = df[df['Medal'].notna()]

